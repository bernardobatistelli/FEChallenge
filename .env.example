# --- Model provider -------------------------------------------------------
# The agent runs against a deterministic MOCK provider by default, so the app
# works with zero setup, no network, and no API keys. Switch only if you want
# a real model.
AI_PROVIDER=mock            # mock (default) | anthropic | openai | bedrock

# anthropic  (AI_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# openai     (AI_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# bedrock    (AI_PROVIDER=bedrock)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_SESSION_TOKEN=...        # if using temporary credentials
# BEDROCK_MODEL=anthropic.claude-3-5-sonnet-20240620-v1:0

# --- Gateway (optional) ---------------------------------------------------
# Route the anthropic/openai providers through a gateway by setting a base URL
# (applied as the provider baseURL). Works with Vercel AI Gateway or Cloudflare
# AI Gateway. Leave unset to call the provider directly.
# AI_GATEWAY_BASE_URL=https://gateway.ai.cloudflare.com/v1/<account_id>/<gateway>/openai
# AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1

# --- Database -------------------------------------------------------------
# Directory for the file-backed PGlite database. The db:seed process and the
# `next dev` process share this directory so seeded data is visible in the app.
PGLITE_DIR=./.pglite
